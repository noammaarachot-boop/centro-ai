# Copy to .env.local for real values. Never commit actual secrets (FR-19.3).

# PostgreSQL connection string for a managed database (Ch.19: "Managed
# relational database"). Required in production (BR-19.1: prod data must be
# isolated from dev data). If unset in development, the app falls back to an
# embedded local PGlite database automatically — no local Postgres install
# needed to get started.
DATABASE_URL=

# Shared secret required in the Authorization header ("Bearer <secret>")
# of POST /api/cron/tick — the scheduled-tasks endpoint an external cron
# (Vercel Cron, GitHub Actions, etc.) hits to evaluate idle conversations
# and send reminders (Ch.16/Ch.18). Required in production; optional in
# development so a fresh checkout can call the endpoint without setup.
CRON_SECRET=

# Gmail account POST /api/contact (the landing page's contact form) sends
# through, via SMTP + an App Password — no domain verification or DNS
# records required. The account needs 2-Step Verification enabled; generate
# the app password at https://myaccount.google.com/apppasswords. Gmail
# always sends as this authenticated account regardless of any other
# "from" configuration (anti-spoofing), so it's also the visible sender.
# Never exposed to the client.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# The inbox that receives contact-form submissions. Defaults to
# Centro.ai.team@gmail.com in code if unset. In the simplest setup this is
# the same address as GMAIL_USER (the account emails itself).
CONTACT_EMAIL_TO=

# --- Google Drive OAuth (src/lib/googleAuth/, src/app/api/auth/google/*) ---
# Not a secret — also read client-side (Google's own Picker widget needs
# it). From the OAuth 2.0 Client ID created in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Server-only. From the same OAuth 2.0 Client ID as above. Never exposed
# to the client.
GOOGLE_CLIENT_SECRET=

# Must exactly match one of the Client ID's "Authorized redirect URIs" in
# Google Cloud Console. Example: https://centro-ai.co.il/api/auth/google/callback
# (or http://localhost:3000/api/auth/google/callback in local development).
GOOGLE_OAUTH_REDIRECT_URI=

# A separate Google Cloud "API key" (not the OAuth client secret),
# restricted to the Google Picker API and to this site's HTTP referrers.
# Used client-side to open the "select an existing folder" picker.
NEXT_PUBLIC_GOOGLE_API_KEY=

# 32-byte key, base64-encoded, used to encrypt stored Google access/refresh
# tokens at rest (AES-256-GCM). Generate with `openssl rand -base64 32`.
# Required in production; without it, connecting Google Drive fails safely
# with a clear error rather than storing tokens in plaintext.
GOOGLE_TOKEN_ENCRYPTION_KEY=

# --- WhatsApp Cloud API (src/lib/whatsapp/, src/app/api/auth/whatsapp/*,
# src/app/api/webhooks/whatsapp) ---
# All of these require Centro's own Meta Business Manager / App Dashboard
# access (Business Verification, a Meta App with the WhatsApp product,
# a System User, and an Embedded Signup Configuration) — none can be
# generated in code. Architecture: Centro acts as a Meta Tech Provider —
# one shared System User token sends/receives for every connected
# organization's number (see the WhatsApp plan), unlike Google Drive's
# per-org OAuth tokens.

# Meta App ID. Not a secret — also read client-side (WhatsAppConnectButton
# needs it to init the Facebook JS SDK for Embedded Signup).
NEXT_PUBLIC_WHATSAPP_APP_ID=

# Server-only. From the same Meta App as above. Used to exchange the
# Embedded Signup `code` for a token and to verify webhook signatures.
# Never exposed to the client.
WHATSAPP_APP_SECRET=

# The one shared, long-lived System User access token used for every
# Cloud API call (sending/receiving messages, subscribing webhooks,
# looking up phone numbers) across every connected organization, scoped
# per-call by that organization's phone_number_id. Never exposed to the
# client.
WHATSAPP_SYSTEM_USER_TOKEN=

# Optional. Only needed if the app's "Valid OAuth Redirect URIs" (Facebook
# Login for Business settings) has an entry configured — Meta then
# requires that same value echoed back exactly on the server-side
# Embedded Signup code exchange, or it fails with error_subcode 36008.
# Must match that dashboard value byte-for-byte. Leave unset if no
# redirect URI is configured there (Meta's own base sample needs none).
WHATSAPP_OAUTH_REDIRECT_URI=

# Embedded Signup Configuration ID, created in the Meta App Dashboard.
# Not a secret — read client-side by WhatsAppConnectButton's FB.login()
# call.
NEXT_PUBLIC_WHATSAPP_CONFIG_ID=

# Self-chosen secret, entered into Meta's webhook configuration screen —
# verified against the `hub.verify_token` query param on the webhook's
# GET handshake (src/app/api/webhooks/whatsapp/route.ts).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Centro's own sales WhatsApp number's phone_number_id — used only for
# Feature 1 (the automatic lead-welcome message after a contact-form
# submission), never for a customer organization's own conversations.
CENTRO_WHATSAPP_PHONE_NUMBER_ID=

# The Meta-approved Message Template name used for that same lead-welcome
# send — WhatsApp forbids free-form messages to anyone who hasn't
# messaged the business first, so this must be a pre-approved template.
WHATSAPP_LEAD_WELCOME_TEMPLATE_NAME=
