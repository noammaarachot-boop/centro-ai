# Copy to .env.local for real values. Never commit actual secrets (FR-19.3).

# PostgreSQL connection string for a managed database (Ch.19: "Managed
# relational database"). Required in production (BR-19.1: prod data must be
# isolated from dev data). If unset in development, the app falls back to an
# embedded local PGlite database automatically — no local Postgres install
# needed to get started.
DATABASE_URL=

# Shared secret required in the Authorization header ("Bearer <secret>")
# of POST /api/cron/tick — the scheduled-tasks endpoint an external cron
# (Vercel Cron, GitHub Actions, etc.) hits to evaluate idle conversations
# and send reminders (Ch.16/Ch.18). Required in production; optional in
# development so a fresh checkout can call the endpoint without setup.
CRON_SECRET=

# Gmail account POST /api/contact (the landing page's contact form) sends
# through, via SMTP + an App Password — no domain verification or DNS
# records required. The account needs 2-Step Verification enabled; generate
# the app password at https://myaccount.google.com/apppasswords. Gmail
# always sends as this authenticated account regardless of any other
# "from" configuration (anti-spoofing), so it's also the visible sender.
# Never exposed to the client.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# The inbox that receives contact-form submissions. Defaults to
# Centro.ai.team@gmail.com in code if unset. In the simplest setup this is
# the same address as GMAIL_USER (the account emails itself).
CONTACT_EMAIL_TO=

# --- Google Drive OAuth (src/lib/googleAuth/, src/app/api/auth/google/*) ---
# Not a secret — also read client-side (Google's own Picker widget needs
# it). From the OAuth 2.0 Client ID created in Google Cloud Console.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Server-only. From the same OAuth 2.0 Client ID as above. Never exposed
# to the client.
GOOGLE_CLIENT_SECRET=

# Must exactly match one of the Client ID's "Authorized redirect URIs" in
# Google Cloud Console. Example: https://centro-ai.co.il/api/auth/google/callback
# (or http://localhost:3000/api/auth/google/callback in local development).
GOOGLE_OAUTH_REDIRECT_URI=

# A separate Google Cloud "API key" (not the OAuth client secret),
# restricted to the Google Picker API and to this site's HTTP referrers.
# Used client-side to open the "select an existing folder" picker.
NEXT_PUBLIC_GOOGLE_API_KEY=

# 32-byte key, base64-encoded, used to encrypt stored Google access/refresh
# tokens at rest (AES-256-GCM). Generate with `openssl rand -base64 32`.
# Required in production; without it, connecting Google Drive fails safely
# with a clear error rather than storing tokens in plaintext.
GOOGLE_TOKEN_ENCRYPTION_KEY=
